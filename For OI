re.sub(r\"\\s+\", \"_\", text)\n","    text = re.sub(r\"[^\\w가-힣_]\", \"\", text)\n","    text = re.sub(r\"_+\", \"_\", text)\n","    text = text.strip(\"_\")\n","    return text\n","\n","\n","def get_source(cell: dict) -> str:\n","    src = cell.get(\"source\", \"\")\n","    if isinstance(src, list): return \"\".join(src)\n","    return src or \"\"\n","\n","\n","def is_problem_header(title: str) -> bool:\n","    return BOJ_RE.search(title) is not None\n","\n","\n","def append_text(path: Path, text: str) -> None:\n","    path.parent.mkdir(parents=True, exist_ok=True) # 폴더 생성\n","\n","    old = path.read_text(encoding=\"utf-8\") if path.exists() else \"\"\n","    block = text.strip()\n","    if not block: return\n","\n","    if old.strip():\n","        new_text = old.rstrip() + \"\\n\\n\" + block + \"\\n\"\n","    else:\n","        new_text = block + \"\\n\"\n","\n","    path.write_text(new_text, encoding=\"utf-8\")\n","\n","\n","def write_text(path: Path, text: str) -> None:\n","    path.parent.mkdir(parents=True, exist_ok=True)\n","    if not text.endswith(\"\\n\"):\n","        text += \"\\n\"\n","    path.write_text(text, encoding=\"utf-8\")\n","\n","\n","def first_nonempty_line(text: str) -> str:\n","    for line in text.splitlines():\n","        if line.strip():\n","            return line.strip()\n","    return \"\"\n","\n","\n","# -----------------------------\n","# 메인 파싱\n","# -----------------------------\n","def parse_notebook(ipynb_path: Path, output_dir: Path) -> None:\n","    with open(ipynb_path, \"r\", encoding=\"utf-8\") as f:\n","        nb = json.load(f)\n","\n","    # output 초기화\n","    if output_dir.exists():\n","        shutil.rmtree(output_dir)\n","    output_dir.mkdir(parents=True, exist_ok=True)\n","\n","    current_path: list[str] = []\n","    current_problem: dict | None = None\n","    skip_mode = False\n","\n","    for cell in nb.get(\"cells\", []):\n","        cell_type = cell.get(\"cell_type\")\n","        source = get_source(cell)\n","\n","        if not source.strip(): continue\n","\n","        # -------------------------\n","        # markdown 처리\n","        # -------------------------\n","        if cell_type == \"markdown\":\n","            first_line = first_nonempty_line(source)\n","            m = HEADER_RE.match(first_line)\n","\n","            # 헤더인 경우\n","            if m:\n","                level = len(m.group(1))\n","\n","                #level normalize\n","                while level<lev[-1][1]:\n","                  lev.pop()\n","                if level>lev[-1][1]:\n","                  lev.append((lev[-1][0]+1,level))\n","                level=lev[-1][0]\n","\n","                title = m.group(2).strip()\n","\n","                # 대단원 (헤더 1개)\n","                if level == 1:\n","                    if title in IGNORE_H1:\n","                        skip_mode = True\n","                        current_problem = None\n","                        continue\n","                    else:\n","                        skip_mode = False\n","                        current_path = [slug(title)]\n","                        current_problem = None\n","                        continue\n","\n","                # 무시 섹션 내부면 건너뜀\n","                if skip_mode: continue\n","\n","                # 문제 헤더 처리\n","                if is_problem_header(title):\n","                    if not current_path:\n","                        # 상위 알고리즘 경로가 없으면 저장 안 함\n","                        current_problem = None\n","                        continue\n","\n","                    current_problem = {\n","                        \"code_idx\": 0,\n","                    }\n","\n","                    current_path = current_path[: level - 1] + [slug(title)]\n","                    continue\n","\n","                # 문제가 아니면 알고리즘 분류임\n","\n","                current_path = current_path[: level - 1] + [slug(title)]  ###\n","                current_problem = None\n","                continue\n","\n","            # 일반 markdown 본문 (header 없음)\n","            if skip_mode: continue\n","\n","            text = source.strip()\n","\n","            if current_problem is not None:\n","                note_path = output_dir / Path(*current_path) / \"note.md\"\n","                append_text(note_path, text)\n","            else:\n","                if not current_path: continue\n","                concept_path = output_dir / Path(*current_path) / \"concept.md\"\n","                append_text(concept_path, text)\n","\n","        # -------------------------\n","        # code 처리\n","        # -------------------------\n","        elif cell_type == \"code\":\n","            if skip_mode:\n","                continue\n","\n","            if current_problem is None:\n","                continue\n","\n","            current_problem[\"code_idx\"] += 1\n","            idx = current_problem[\"code_idx\"]\n","\n","\n","            code_path = output_dir / Path(*current_path) / f\"solution_{idx}.py\"\n","\n","            code_text = get_source(cell)\n","            if not code_text.endswith(\"\\n\"):\n","                code_text += \"\\n\"\n","\n","            write_text(code_path, code_text)\n","\n","\n","def main() -> None:\n","    parse_notebook(INPUT_IPYNB, OUTPUT_DIR)\n","    print(f\"Done: {OUTPUT_DIR}\")\n","\n","\n","if __name__ == \"__main__\":\n","    main()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"OnKZtNm0Rm1Q","executionInfo":{"status":"ok","timestamp":1776001058159,"user_tz":-540,"elapsed":6783,"user":{"displayName":"최명훈","userId":"03888429607472953947"}},"outputId":"8bd930c7-14eb-4f43-bcfd-6ea9a3d605d6"},"execution_count":38,"outputs":[{"output_type":"stream","name":"stdout","text":["Done: /content/drive/MyDrive/Colab Notebooks/PS/output\n"]}]},{"cell_type":"code","source":["import subprocess\n","from pathlib import Path\n","\n","# repo 루트 폴더\n","REPO_ROOT = Path(\"/content/drive/MyDrive/Colab Notebooks/PS\")\n","\n","def run(cmd, cwd=REPO_ROOT, check=True):\